[Unit]
Description=MagiesShell Stats API
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/magies-shell-stats/api
EnvironmentFile=/opt/magies-shell-stats/api/.env
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
